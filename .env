# Markdown转换工具配置文件
# 请根据实际情况修改以下配置

# ==================== 通用配置 ====================

# 默认输入目录（如果命令行未指定）
DEFAULT_INPUT_DIR=../Proposal

# 默认输出目录（如果命令行未指定）
DEFAULT_OUTPUT_DIR=../Proposal

# ==================== PDF配置（wkhtmltopdf版本）====================

# wkhtmltopdf可执行文件路径（留空则自动查找）
WKHTMLTOPDF_PATH=

# PDF页面大小（A4, A3, Letter等）
PDF_PAGE_SIZE=A4

# PDF边距（单位：mm）
PDF_MARGIN_TOP=15
PDF_MARGIN_RIGHT=15
PDF_MARGIN_BOTTOM=15
PDF_MARGIN_LEFT=15

# 是否启用JavaScript（true/false）
PDF_ENABLE_JAVASCRIPT=true

# JavaScript延迟时间（毫秒）
PDF_JAVASCRIPT_DELAY=200

# ==================== PDF配置（Chromium版本）====================

# 是否打印背景（true/false）
CHROMIUM_PRINT_BACKGROUND=true

# 是否启用彩色emoji（true/false）
CHROMIUM_COLOR_EMOJI=true

# ==================== CSS样式配置 ====================

# 主字体（优先使用emoji字体）
FONT_FAMILY=Segoe UI Emoji, Apple Color Emoji, Noto Color Emoji, Microsoft YaHei, 微软雅黑, Arial, sans-serif

# 基础字体大小（pt）
FONT_SIZE=12

# 行高
LINE_HEIGHT=1.6

# 主标题字体大小（pt）
H1_FONT_SIZE=24

# 二级标题字体大小（pt）
H2_FONT_SIZE=20

# 三级标题字体大小（pt）
H3_FONT_SIZE=16

# 主题色（用于标题下划线、表格等）
PRIMARY_COLOR=#3498db

# 表格头部背景色
TABLE_HEADER_COLOR=#3498db

# 代码块背景色
CODE_BACKGROUND_COLOR=#f4f4f4

# ==================== Markdown扩展 ====================

# 启用的markdown2扩展（逗号分隔）
MARKDOWN_EXTRAS=tables,fenced-code-blocks,code-friendly,break-on-newline,header-ids

# ==================== 其他配置 ====================

# 是否显示详细日志（true/false）
VERBOSE=true

# 编码
ENCODING=UTF-8
