# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# IDE
.idea/
.vscode/

# 环境配置
.env.local

# 临时文件
Tmp/

# 日志
Logs/

# Input 目录 - 只保留 Tests 和 Samples 目录结构及 .md 文件
Input/*
!Input/Tests/
!Input/Samples/
Input/Tests/*
Input/Samples/*
!Input/Tests/.gitkeep
!Input/Samples/.gitkeep
!Input/Tests/*.md
!Input/Samples/*.md

# Output 目录 - 只保留目录结构和 .gitkeep，不提交任何生成文件
Output/*
!Output/html/
!Output/pdf/
!Output/docx/
Output/html/*
Output/pdf/*
Output/docx/*
!Output/html/Tests/
!Output/html/Samples/
!Output/pdf/Tests/
!Output/pdf/Samples/
!Output/docx/Tests/
!Output/docx/Samples/
Output/html/Tests/*
Output/html/Samples/*
Output/pdf/Tests/*
Output/pdf/Samples/*
Output/docx/Tests/*
Output/docx/Samples/*
!Output/html/Tests/.gitkeep
!Output/html/Samples/.gitkeep
!Output/pdf/Tests/.gitkeep
!Output/pdf/Samples/.gitkeep
!Output/docx/Tests/.gitkeep
!Output/docx/Samples/.gitkeep
